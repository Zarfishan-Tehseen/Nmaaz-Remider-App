<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.NmaazReminder" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">#0D3E31</item>
        <item name="colorOnPrimary">#FFFFFF</item>
        <item name="colorSecondary">#EAE6DC</item>
        <item name="colorOnSecondary">#2E312F</item>

        <item name="colorPrimaryContainer">#D4E7E1</item>

        <item name="colorOnPrimaryContainer">@color/light_green</item>

        <item name="colorControlHighlight">#E5E5E5</item>
    </style>

    <style name="Theme.NmaazReminder" parent="Base.Theme.NmaazReminder">

    </style>

    <style name="SettingsLabel">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginTop">24dp</item>
        <item name="android:layout_marginStart">24dp</item>
        <item name="android:layout_marginBottom">8dp</item>
        <item name="android:textColor">#2D3436</item>
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="SettingsCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:layout_marginEnd">16dp</item>
        <item name="android:layout_marginBottom">8dp</item>

        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">#E0E0E0</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Divider">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">1dp</item>
        <item name="android:background">#F1F2F6</item>
    </style>


    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/green</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.NmaazReminder</item>
    </style>

    <style name="Widget.Sakinah.PresetChip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipBackgroundColor">@color/preset_chip_bg_color_selector</item>
        <item name="android:textColor">@color/preset_chip_text_color_selector</item>
        <item name="chipCornerRadius">24dp</item>
        <item name="chipStrokeWidth">0dp</item>
        <item name="showMotionSpec">@null</item>
        <item name="hideMotionSpec">@null</item>
    </style>

</resources>