<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:paddingTop="0dp"
    android:background="@drawable/bg_arch_line2">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="24dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/layoutArchHero"
            android:layout_width="0dp"
            android:layout_height="320dp"
            android:layout_marginStart="20dp"
            android:layout_marginEnd="20dp"
            android:layout_marginTop="100dp"
            android:background="@android:color/transparent"
            android:paddingHorizontal="24dp"
            android:paddingTop="45dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/tvTimeFor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TIME FOR"
                android:textColor="@color/gold_text"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
            <TextView
                android:id="@+id/tvArchNextPrayerArabic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="العشاء"
                android:textColor="@color/gold_text"
                android:textSize="26sp"
                android:fontFamily="@font/amiri"
                app:layout_constraintTop_toBottomOf="@id/tvArchNextPrayerTitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <LinearLayout
                android:id="@+id/llviews"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/tvArchNextPrayerArabic"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <View
                    android:layout_width="30dp"
                    android:layout_height="2dp"
                    android:background="@color/gold_text"
                    android:layout_marginHorizontal="5dp"/>
                <View
                    android:layout_width="5dp"
                    android:layout_height="5dp"
                    android:background="@drawable/bg_close_circle"
                    android:backgroundTint="@color/gold_text"/>
                <View
                    android:layout_width="30dp"
                    android:layout_height="2dp"
                    android:background="@color/gold_text"
                    android:layout_marginHorizontal="5dp"
                    />
            </LinearLayout>

            <TextView
                android:id="@+id/tvArchNextPrayerTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="ISHA"
                android:textColor="@color/white"
                android:textSize="30sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:fontFamily="@font/playfair_display"
                app:layout_constraintTop_toBottomOf="@id/tvTimeFor"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tvArchNextPrayerTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="8:15 PM"
                android:textColor="@color/white"
                android:textSize="30sp"
                android:fontFamily="@font/cinzel_decorative"
                app:layout_constraintTop_toBottomOf="@id/llviews"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <TextView
                android:id="@+id/tv_begins"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BEGINS IN"
                android:textSize="13sp"
                android:textColor="@color/stroke_color"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/tvArchNextPrayerTime"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <LinearLayout
                android:id="@+id/layoutArchCountdown"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:orientation="horizontal"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/tv_begins"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="54dp"
                    android:layout_height="64dp"
                    android:background="@android:color/transparent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvArchCountdownHours"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="02"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:fontFamily="@font/cinzel_decorative"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="hours"
                        android:textColor="#99B5A9"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="6dp"
                    android:layout_marginBottom="12dp"
                    android:text=":"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="54dp"
                    android:layout_height="64dp"
                    android:background="@android:color/transparent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvArchCountdownMinutes"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="45"
                        android:textColor="@color/white"
                        android:textSize="28sp"
                        android:fontFamily="@font/cinzel_decorative"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="mins"
                        android:textColor="#99B5A9"
                        android:textSize="10sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="6dp"
                    android:layout_marginBottom="12dp"
                    android:text=":"
                    android:textColor="#FFFFFF"
                    android:textSize="24sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:layout_width="54dp"
                    android:layout_height="64dp"
                    android:background="@android:color/transparent"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:id="@+id/tvArchCountdownSeconds"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12"
                        android:textColor="@color/white"
                        android:fontFamily="@font/cinzel_decorative"
                        android:textSize="28sp"
                        android:textStyle="bold" />
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="secs"
                        android:textColor="#99B5A9"
                        android:textSize="10sp" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="until jamaat call reminder alert"
                android:textColor="#8AA69A"
                android:textSize="11sp"
                app:layout_constraintTop_toBottomOf="@id/layoutArchCountdown"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cvArchPrayerContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="100dp"
            android:layout_marginHorizontal="20dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/_6aecb576"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@color/opac_green"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvArchPrayerList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="5dp"
                android:paddingHorizontal="6dp"
                android:nestedScrollingEnabled="false"
                android:clipToPadding="false" />

        </com.google.android.material.card.MaterialCardView>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>