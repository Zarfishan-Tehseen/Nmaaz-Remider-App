<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_row_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:paddingHorizontal="16dp">

        <View
            android:id="@+id/view_radio_indicator"
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:background="@drawable/ic_radio_unselected" />

        <TextView
            android:id="@+id/tv_script_sample"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:textColor="#7A7A7A"
            android:textSize="15sp"
            tools:text="Fajr · الفجر" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toEndOf="@id/view_radio_indicator"
            android:layout_toStartOf="@id/tv_script_sample"
            android:layout_marginStart="16dp"
            android:layout_centerVertical="true"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_language_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#111111"
                android:textSize="16sp"
                android:textStyle="bold"
                tools:text="English + Arabic" />

            <TextView
                android:id="@+id/tv_language_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#7A7A7A"
                android:textSize="13sp"
                android:layout_marginTop="2dp"
                android:visibility="visible"
                tools:text="Arabic interface" />
        </LinearLayout>

    </RelativeLayout>

    <View
        android:id="@+id/language_divider"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginStart="54dp"
        android:background="#EAEAEA" />

</LinearLayout>