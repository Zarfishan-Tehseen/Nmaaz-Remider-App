<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F5F0">

    <RelativeLayout
        android:id="@+id/layout_static_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#F7F5F0"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/layout_location_selector"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_location"
                app:tint="#6E726E" />

            <TextView
                android:id="@+id/tv_current_location"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:text="Karachi, Pakistan"
                android:textColor="#333333"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="14dp"
                android:layout_height="14dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_arrow_drop_down"
                app:tint="#6E726E" />
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#EAE6DC">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="2dp">

                <TextView
                    android:id="@+id/btn_toggle_list"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_segmented_active"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="List"
                    android:textColor="@android:color/white"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btn_toggle_dial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Dial"
                    android:textColor="#6E726E"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/btn_toggle_arch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="6dp"
                    android:text="Arch"
                    android:textColor="#6E726E"
                    android:textSize="12sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </RelativeLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/layout_static_header"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingTop="4dp"
            android:paddingBottom="16dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="24dp"
                app:cardElevation="0dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_green_card_with_pattern"
                    android:padding="20dp">

                    <LinearLayout
                        android:id="@+id/layout_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <View
                            android:layout_width="6dp"
                            android:layout_height="6dp"
                            android:background="@drawable/shape_dot_indicator" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="NEXT PRAYER"
                            android:textColor="#E0A96D"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />
                    </LinearLayout>

                    <TextView
                        android:id="@+id/tv_next_prayer_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/layout_badge"
                        android:layout_marginTop="8dp"
                        android:fontFamily="@font/playfair_display"
                        android:text="Asr"
                        android:textColor="@android:color/white"
                        android:textSize="36sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_next_prayer_arabic"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tv_next_prayer_title"
                        android:fontFamily="@font/amiri"
                        android:text="العصر"
                        android:textColor="#E0A96D"
                        android:textSize="22sp" />

                    <TextView
                        android:id="@+id/tv_next_prayer_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/tv_next_prayer_arabic"
                        android:layout_marginTop="12dp"
                        android:fontFamily="@font/cinzel_decorative"
                        android:text="4:25 PM"
                        android:textColor="@android:color/white"
                        android:textSize="28sp" />

                    <ImageView
                        android:id="@+id/iv_weather_accent"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_alignParentEnd="true"
                        android:layout_marginTop="12dp"
                        android:src="@drawable/ic_sun_cloud_accent" />

                    <View
                        android:id="@+id/card_divider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_below="@id/tv_next_prayer_time"
                        android:layout_marginTop="20dp"
                        android:layout_marginBottom="16dp"
                        android:background="#1E5447" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_below="@id/card_divider"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="TIME REMAINING"
                            android:textColor="#8AAEA5"
                            android:textSize="11sp"
                            android:textStyle="bold"
                            android:letterSpacing="0.05" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:orientation="horizontal">

                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">

                                <TextView
                                    android:id="@+id/tv_countdown_hours"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/cinzel_decorative"
                                    android:text="01"
                                    android:textColor="@android:color/white"
                                    android:textSize="26sp"
                                    android:textStyle="bold" />
                                <TextView android:layout_width="wrap_content"  android:layout_height="wrap_content" android:text="HR" android:textColor="#8AAEA5" android:textSize="10sp"/>
                            </LinearLayout>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/cinzel_decorative" android:text=":" android:textColor="@android:color/white" android:textSize="24sp" android:layout_marginHorizontal="12dp"/>

                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                                <TextView android:id="@+id/tv_countdown_minutes" android:fontFamily="@font/cinzel_decorative" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="54" android:textColor="@android:color/white" android:textSize="26sp" android:textStyle="bold"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MIN" android:textColor="#8AAEA5" android:textSize="10sp"/>
                            </LinearLayout>

                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/cinzel_decorative" android:text=":" android:textColor="@android:color/white" android:textSize="24sp" android:layout_marginHorizontal="12dp"/>

                            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" android:gravity="center">
                                <TextView android:id="@+id/tv_countdown_seconds" android:fontFamily="@font/cinzel_decorative" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="52" android:textColor="@android:color/white" android:textSize="26sp" android:textStyle="bold"/>
                                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SEC" android:textColor="#8AAEA5" android:textSize="10sp"/>
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>
                </RelativeLayout>
            </androidx.cardview.widget.CardView>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerVertical="true"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tv_calendar_gregorian"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monday, 18 May"
                        android:textColor="#222222"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_calendar_hijri"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="1 Dhul Hijjah 1447"
                        android:textColor="#6E726E"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageButton
                        android:id="@+id/btn_date_prev"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_date_action"
                        android:src="@drawable/ic_chevron_left"
                        app:tint="#333333" />

                    <TextView
                        android:id="@+id/btn_date_today"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_date_action"
                        android:gravity="center"
                        android:paddingHorizontal="16dp"
                        android:text="Today"
                        android:textColor="#333333"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif-medium" />

                    <ImageButton
                        android:id="@+id/btn_date_next"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_date_action"
                        android:src="@drawable/ic_chevron_right"
                        app:tint="#333333" />
                </LinearLayout>
            </RelativeLayout>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:cardBackgroundColor="@android:color/white">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_prayer_list"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="24dp"
                    android:paddingTop="16dp"
                    android:clipToPadding="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    android:orientation="vertical" />
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>